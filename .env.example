# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o arquivo .env real

# ===================
# Database (Docker)
# ===================
POSTGRES_DB=studio_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=seu_password_seguro_aqui

# ===================
# Backend Node.js
# ===================
PORT=4000
NODE_ENV=production
JWT_SECRET=seu_jwt_secret_muito_seguro_aqui

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua_chave_aqui

# Zabbix
ZABBIX_URL=https://seu-zabbix.com
ZABBIX_USER=seu_usuario
ZABBIX_PASSWORD=sua_senha

# Google AI
GOOGLE_API_KEY=sua_api_key_aqui
GOOGLE_GENAI_API_KEY=sua_genai_key_aqui

# Split.io Feature Flags
SPLIT_API_KEY=sua_split_api_key

# ===================
# Frontend Next.js
# ===================
# URLs das APIs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_PYTHON_API_URL=http://localhost:5000

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=sua_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","storageBucket":"...","messagingSenderId":"...","appId":"..."}

# Split.io (Client SDK)
NEXT_PUBLIC_SPLIT_CLIENT_SDK_KEY=sua_split_client_key

# WhatsApp Provider (opcional)
WHATSAPP_PROVIDER=GZAPPY
GZAPPY_TOKEN=Bearer seu_token_aqui

# ===================
# URLs para VMs
# ===================
# Dev VM
# NEXT_PUBLIC_API_URL=http://ip-vm-dev:4000

# Prod VM
# NEXT_PUBLIC_API_URL=http://ip-vm-prod:4000
# Ou com domínio:
# NEXT_PUBLIC_API_URL=https://api.seu-dominio.com
